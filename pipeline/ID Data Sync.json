= A.CompanyNumber                                      \n\tWHERE \n\tA.CompanyNumber ='01DEP' AND A.DivisionID ='01DEP'  \n\t--AND  a.customercode = '0000000132'\n\tAND CustomerStatus ='Active'\n\tAND a.customercode not like '?%'              \n\tAND a.customercode not like '.%'           \n\tand a.customercode not like ' %'           \n\tand CustomerName NOT LIKE '%' + CHAR(26) + '%'  \n\tand a.customercode in ( select distinct customercode from dev.DimContactByBusinessPartner)   ",
