						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT \n\t'E1E0CF64-61A9-EF11-B8E9-000D3A196181' AS eet_businessunit,\n    2 AS quantitydecimal,\n    'FAC06D02-8BE7-4453-A542-21509C1CFAC1' AS defaultuomid,\n    '0456FB13-F9AC-EF11-8A66-000D3A106B21' AS organizationid,\n    'D287CEFE-9958-4FF4-B048-81816AAB20DA' AS defaultuomscheduleid,\n    'true' AS isstockitem,\n    'FE9D7169-7DBB-EF11-B8E8-7C1E524857A0' AS pricelevelid,\n\tCONCAT(UnitNumber, '_', LEFT(CompanyNumber, 2)) AS productnumber,\n\t1 productstructure,\n\t'0' AS statecode,\n    TRIM(UnitNumber) AS eet_unitnumber,\n    Manufacturer AS eet_make,\n    TRIM(Model) AS eet_modelcode,\n    TRIM(UnitDescription) AS eet_fullname,\n    CASE      \n        WHEN Used = 'Used' THEN 'true'      \n        WHEN Used = 'New' THEN 'false'      \n        ELSE 'false'      \n    END AS eet_neworused,\n    TRY_CONVERT(date, SalesInvoiceDate) AS eet_purchasedate,\n    ModelYear AS eet_makeyear,\n    CASE      \n        WHEN OwnershipStatus = 'Dealer Owned' THEN 10      \n        WHEN OwnershipStatus = 'Customer Stock' THEN 20      \n        ELSE NULL      \n    END AS eet_ownershipstatus,\n    CONCAT(TRIM(Model), '_', Manufacturer) AS name,\n    SerialNumber eet_serialno,\n    CASE      \n        WHEN [Status] = 'RENTED' THEN '276040002'      \n        WHEN [Status] = 'SOLD' THEN '276040003'      \n        WHEN [Status] = 'ON ORDER' THEN '276040004'      \n        WHEN [Status] = 'TRANSFER' THEN '276040006'      \n        ELSE '276040000'      \n    END AS EquipmentStatus,\n    '200001' AS producttypecode,\n    LEFT(ManufacturerName, 10) AS eet_manufacturer,\n    TRIM(Model) AS ModelName,\n    CASE\n        WHEN PhysicalStatus = 'RENTAL' THEN 3      \n        WHEN PhysicalStatus = 'In the Branch' THEN 2      \n        WHEN PhysicalStatus = 'DEMO' THEN 5      \n        WHEN PhysicalStatus = 'LOANER' THEN 6      \n        WHEN PhysicalStatus IN ('IN TRANSIT', 'BEING TRANSFERRED') THEN 7\n        WHEN PhysicalStatus = 'EQUIPMENT SALE' THEN 4      \n        WHEN PhysicalStatus = 'SERVICE' THEN 14      \n        WHEN PhysicalStatus = 'HELD' THEN 15      \n        ELSE NULL      \n    END AS eet_physicalstatus,\n    [Purchase ORDER] AS PurchaseOrder,\n    [Purchase Price] AS eet_purchaseprice,\n    NULL AS PurchaseOrderDate,\n\tTRY_CONVERT(DATE, CreatedDate) AS createdon,\n\tTRY_CONVERT(DATE, Modifieddate) AS modifiedon,\n    NULL AS ExpectedReceiptDate,\n    TRY_CONVERT(date, [Actual Receipt Date]) AS ActualReceiptDate,\n    OriginalSalesPrice AS SalesPrice,\n    [Sales Agreement Customer] AS SoldToCustomer,\n    NULL AS FinalDeliveryDate,\n    NULL AS ApprovalDate,\n    Meter1Reading AS Meter1Hours,\n    NULL AS Meter2Hours,\n    MinimumSellingPrice,\n    Book,\n    '100' AS eet_extendcompany,\n    ParentUnitNumber eet_parentunit,\n    CONCAT(UnitNumber, '_', LEFT(CompanyNumber, 2)) AS ExternalID,\n    NULL AS ConfirmedReceiptDate,\n    Price price,\n    ModelName AS description,\n    LEFT(CompanyNumber, 2) AS Company,\n    LEFT(DivisionID, 2) AS Division,\n    Cost AS standardcost\nFROM      \n    [dev].DimEquipment E WITH (NOLOCK)      \nWHERE       \n    CompanyNumber = '01DEP'      \n    AND DivisionID = '01DEP'\n\tAND EquipmentType = 'Attachment' AND ParentUnitNumber <> '';\n",
