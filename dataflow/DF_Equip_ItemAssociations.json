{
	"name": "DF_Equip_ItemAssociations",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable2",
						"type": "DatasetReference"
					},
					"name": "GetUnitNumber"
				},
				{
					"dataset": {
						"referenceName": "DynamicsCrmEntity_Lookup",
						"type": "DatasetReference"
					},
					"name": "GetProductFromCRM"
				},
				{
					"dataset": {
						"referenceName": "DynamicsCrmEntity_Lookup1",
						"type": "DatasetReference"
					},
					"name": "GetproductIDfromProduct"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DynamicsCrmEntity",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "AlterRow1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "lookup2"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Token as string",
				"}",
				"source(output(",
				"          UnitNumber as string,",
				"          Model as string,",
				"          eet_effectivedate as date,",
				"          eet_expirydate as date,",
				"          eet_price as decimal(20,4),",
				"          eet_costprice as decimal(20,4),",
				"          eet_businessunit as string,",
				"          organizationid as string,",
				"          EquipmentType as string,",
				"          name as string,",
				"          statecode as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     procedureName: 'EquipmentItemAssociations',",
				"     schemaName: 'depapi',",
				"     resultSet: true,",
				"     format: 'procedure',",
				"     booleanFormat: ['true', 'false']) ~> GetUnitNumber",
				"source(output(",
				"          {@odata.etag} as string,",
				"          eet_modelcode as string,",
				"          eet_parentproductitemid as string,",
				"          name as string,",
				"          productid as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     query: '<fetch>\\n   <entity name=\"product\">\\n       <attribute name=\"eet_unitnumber\" />\\n       <attribute name=\"productid\" alias=\"eet_parentproductitemid\"/>\\n       <attribute name=\"name\" />\\n       <attribute name=\"eet_modelcode\" />\\n       <filter>\\n           <condition attribute=\"eet_modelcode\" operator=\"eq\" value=\"C-99\" />\\n           <condition attribute=\"eet_unitnumber\" operator=\"null\" />\\n       </filter>\\n   </entity>\\n</fetch>\\n') ~> GetProductFromCRM",
				"source(output(",
				"          {@odata.etag} as string,",
				"          eet_childproductitemid as string,",
				"          eet_unitnumber as string,",
				"          name as string,",
				"          productid as string,",
				"          productnumber as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     query: '<fetch>\\n   <entity name=\"product\" >\\n       <attribute name=\"productid\" alias=\"eet_childproductitemid\"/>\\n       <attribute name=\"productnumber\" />\\n       <attribute name=\"name\" />\\n       <attribute name=\"eet_unitnumber\" />\\n       <filter>\\n           <condition attribute=\"eet_modelcode\" operator=\"eq\" value=\"C-99\" />\\n           <condition attribute=\"eet_unitnumber\" operator=\"not-null\" />\\n       </filter>\\n   </entity>\\n</fetch>\\n') ~> GetproductIDfromProduct",
				"GetProductFromCRM, GetproductIDfromProduct lookup(GetProductFromCRM@name == GetproductIDfromProduct@name,",
				"     multiple: true,",
				"     broadcast: 'auto',",
				"     pickup: 'any')~> lookup1",
				"lookup2 alterRow(upsertIf(true())) ~> AlterRow1",
				"AlterRow1 derive({eet_parentproductitemid@odata.bind} = \"/products(\" + eet_parentproductitemid + \")\",",
				"          {eet_childproductitemid@odata.bind} = \"/products(\" + eet_childproductitemid + \")\",",
				"          {eet_businessunit@odata.bind} = \"/businessunits(\" + eet_businessunit + \")\") ~> derivedColumn1",
				"lookup1, GetUnitNumber lookup(GetProductFromCRM@name == GetUnitNumber@name,",
				"     multiple: true,",
				"     broadcast: 'auto',",
				"     pickup: 'any')~> lookup2",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     alternateKeyName: 'crdb8_parentchildproductid',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          {eet_parentproductitemid@odata.bind},",
				"          {eet_childproductitemid@odata.bind},",
				"          eet_costprice,",
				"          eet_price,",
				"          {eet_businessunit@odata.bind},",
				"          eet_effectivedate,",
				"          eet_expirydate,",
				"          statecode",
				"     )) ~> sink1"
			]
		}
	}
}